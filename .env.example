# Gmail OAuth (from scripts/gmail_auth.py)
GMAIL_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"..."}}
GMAIL_REFRESH_TOKEN=1//...

# Alert senders (comma-separated; supports domains like "redfin.com")
ALERT_SENDERS=redfin.com,alerts@example.com

# Date-filtered senders: "email:days" — only fetch emails newer than N days
# Useful for personal contacts who may forward listing links
SENDER_DATE_FILTERS=friend@example.com:21

# Anthropic API key (for LLM fallback parser + AI evaluation)
ANTHROPIC_API_KEY=sk-ant-...

# AI evaluation model (default: claude-haiku-4-5-20251001)
# AI_EVAL_MODEL=claude-haiku-4-5-20251001

# Database (Postgres on Heroku, SQLite locally)
DATABASE_URL=sqlite:///listings.db

# Auth: comma-separated emails allowed to access the dashboard
ALLOWED_EMAILS=you@example.com,friend@example.com

# Session signing key (optional — auto-derived from credentials if not set)
# SESSION_SECRET=

# Scheduled polling interval in hours (0 = disabled, default = 1)
POLL_INTERVAL_HOURS=1

# SchoolDigger API (free dev tier: 20 calls/day)
# Register at https://developer.schooldigger.com/
SCHOOLDIGGER_APP_ID=
SCHOOLDIGGER_APP_KEY=

# Google Maps / Routes API (Essentials tier: 10K free/month)
GOOGLE_MAPS_API_KEY=

# Commute destination (default: Brookfield Place)
# COMMUTE_DESTINATION=Brookfield Place, 230 Vesey St, New York, NY 10281
