# Gmail OAuth (from scripts/gmail_auth.py)
GMAIL_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"..."}}
GMAIL_REFRESH_TOKEN=1//...

# Alert senders (comma-separated)
ALERT_SENDERS=ken.wile@redfin.com,alerts@mls.example.com,noreply@redfin.com

# Anthropic API key (for LLM fallback parser)
ANTHROPIC_API_KEY=sk-ant-...

# Database (Postgres on Heroku, SQLite locally)
DATABASE_URL=sqlite:///listings.db

# Auth: comma-separated emails allowed to access the dashboard
ALLOWED_EMAILS=you@example.com,friend@example.com,alt@example.com

# Session signing key (optional — auto-derived from credentials if not set)
# SESSION_SECRET=
